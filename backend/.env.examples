PORT=8080
NODE_ENV=development

MONGO_URL=your_mongodb_connection_string
SESSION_SECRET=your_session_secret
ADMIN_PASS=your_admin_password

# ── Cloudinary ────────────────────────────────────────────────────────────────
CLOUD_NAME=your_cloudinary_name
CLOUD_API_KEY=your_cloudinary_key
CLOUD_API_SECRET=your_cloudinary_secret

# ── Mapbox ────────────────────────────────────────────────────────────────────
MAP_TOKEN=your_mapbox_token

# ── URLs ──────────────────────────────────────────────────────────────────────
# Base URL of this server — used to build OAuth callback URLs
BASE_URL=http://localhost:8080

# URL of the React frontend — used to redirect after OAuth flow completes
FRONTEND_URL=http://localhost:5173

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI to add:  <BASE_URL>/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── GitHub OAuth ──────────────────────────────────────────────────────────────
# Create an OAuth App at: https://github.com/settings/developers
# Authorization callback URL:  <BASE_URL>/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Security ──────────────────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins (leave empty in dev)
CORS_ORIGINS=

# ── Logging ───────────────────────────────────────────────────────────────────
# Levels: error | warn | info | http | debug  (default: info in prod, debug in dev)
LOG_LEVEL=

# ── Feature flags ─────────────────────────────────────────────────────────────
# Set to "true" to expose Swagger UI in production
SWAGGER_ENABLED=false
